# Copy to .env and adjust as needed.

PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Docker Compose maps Postgres to host port 5433 and Redis to 6380
DATABASE_URL=postgresql://snaploop:snaploop@localhost:5433/snaploop?schema=public
REDIS_URL=redis://localhost:6380

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Leave SMTP_HOST empty to log emails to the console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Snaploop <no-reply@snaploop.local>
SKIP_EMAIL_VERIFICATION=true

STORAGE_DRIVER=local
UPLOAD_DIR=uploads
